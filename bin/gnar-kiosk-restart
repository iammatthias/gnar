#!/bin/bash
# gnar-kiosk-restart — gracefully restart the sway kiosk.
#
# `swaymsg exit` quits sway cleanly; getty@tty1's autologin then respawns it
# via ~/.zprofile with fresh config. Works from any shell (incl. plain ssh):
# it borrows the Wayland session env from a running foot tile so swaymsg can
# reach the compositor.
set -uo pipefail

pid=$(pgrep -x foot | head -1 || true)
if [ -n "${pid:-}" ]; then
    env_of() { tr '\0' '\n' < "/proc/$1/environ" | grep "^$2=" | cut -d= -f2-; }
    WAYLAND_DISPLAY=$(env_of "$pid" WAYLAND_DISPLAY) \
    XDG_RUNTIME_DIR=$(env_of "$pid" XDG_RUNTIME_DIR) \
    SWAYSOCK=$(env_of "$pid" SWAYSOCK) \
        swaymsg exit 2>/dev/null || pkill -x sway || true
else
    pkill -x sway || true
fi

for _ in $(seq 1 30); do
    if pgrep -x sway >/dev/null && [ "$(pgrep -xc foot)" -ge 6 ]; then
        echo "kiosk restarted"
        exit 0
    fi
    sleep 2
done
echo "gnar-kiosk-restart: kiosk did not come back — check getty@tty1 / ~/.zprofile" >&2
exit 1
