# Copy to .env and fill in values for unattended boot.
# Without these, you'll need to run interactive setup commands once
# (see /srv/stack/README — or the closing banner from setup.sh).

# Tailscale machine hostname (also becomes the tailnet hostname).
TS_HOSTNAME=gnar

# Optional: pre-issued one-shot auth key from the Tailscale admin console
# (Settings → Keys → Generate auth key). If set, the tailscale container
# auto-authenticates on first start. If empty, run:
#   docker compose exec tailscale tailscale up
# manually after `docker compose up -d`.
TS_AUTHKEY=

# Extra args passed to `tailscale up` inside the container. --ssh enables
# Tailscale SSH; remove if you don't want that.
TS_EXTRA_ARGS=--ssh

# Path to the (non-root) user's home directory on the host. setup.sh writes
# this at install time. docker-compose bind-mounts this user's ~/.ssh and
# ~/.gitconfig into the hermes container so git inside the container speaks
# as you. If you ever change the username, edit here too and `docker
# compose up -d` to pick up the new mounts.
USER_HOME=/home/iam

# ----- Preview sites (tailnet-private, real LE certs) -----
#
# Apex you own and want to use for previews. Caddy serves a static
# "online" page at this apex and serves every `<name>.<apex>` subdomain
# you create via `add-preview-site <name> <port-or-dir>`.
#
# DNS: in your DNS provider, point this apex and a wildcard at this
# box's tailnet IP, DNS-only (not proxied):
#   $PREVIEW_APEX        A    <tailnet IP>
#   *.$PREVIEW_APEX      A    <tailnet IP>
#
# Off-tailnet clients can't reach the IP (it's CGNAT), so previews stay
# private. Caddy serves a real LE wildcard cert via ACME DNS-01 against
# Cloudflare.
PREVIEW_APEX=previews.example.com

# Cloudflare API token used by caddy for ACME DNS-01.
#
# Generate at:  https://dash.cloudflare.com/profile/api-tokens
# Permissions:  Zone — DNS — Edit, scoped to the zone hosting $PREVIEW_APEX
# (Zone — Zone — Read is also required by the LE module.)
CF_API_TOKEN=

# ----- Cloudflare Tunnel (opt-in public previews) -----
#
# Optional, off by default. Spin up only when you want a *public* URL
# for a specific site (e.g. sharing a preview with someone off-tailnet).
# Subsequent `add-public-site` invocations write public vhosts on caddy's
# :8080 listener which the connector fronts.
CLOUDFLARED_TUNNEL_NAME=gnar
#
# Setup:
#   1. cd ~/gnar && ./scripts/cloudflared-setup.sh
#      (one-time browser auth, then scripted)
#   2. cd /srv/stack && docker compose --profile cloudflared up -d
#   3. `add-public-site <hostname> <port-or-dir>` for each public site.
