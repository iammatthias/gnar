[Unit]
Description=Hermes dashboard (Kanban + sessions UI)
After=network-online.target

[Service]
Type=simple
ExecStart=%h/.local/bin/hermes dashboard --host 0.0.0.0 --port 9119
Restart=on-failure
RestartSec=5
Environment="PATH=%h/.local/bin:%h/.cargo/bin:%h/.npm-global/bin:%h/.bun/bin:/usr/local/bin:/usr/bin:/bin"

[Install]
WantedBy=default.target
