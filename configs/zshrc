# ----- Caddy site management -----

add-site() {
    if [ -z "$1" ]; then
        echo "Usage: add-site <name> [port|directory]"
        echo "Examples:"
        echo "  add-site myapp 3000           # reverse proxy to localhost:3000"
        echo "  add-site static /var/www/site # serve static files"
        return 1
    fi

    local name=$1
    local target=${2:-3000}
    local backup="/etc/caddy/Caddyfile.backup.$(date +%Y%m%d_%H%M%S)"

    sudo cp /etc/caddy/Caddyfile "$backup"

    if [[ "$target" =~ ^[0-9]+$ ]]; then
        echo -e "\n# $name service (reverse proxy)\n$name.local:80 {\n    reverse_proxy localhost:$target\n}" | sudo tee -a /etc/caddy/Caddyfile > /dev/null
        echo "Added $name.local:80 -> localhost:$target"
    else
        if [ ! -d "$target" ]; then
            echo "Directory $target does not exist"
            return 1
        fi
        echo -e "\n# $name service (static files)\n$name.local:80 {\n    root * $target\n    file_server\n}" | sudo tee -a /etc/caddy/Caddyfile > /dev/null
        echo "Added $name.local:80 -> $target"
    fi

    if caddy validate --config /etc/caddy/Caddyfile 2>/dev/null; then
        sudo systemctl reload caddy
        echo "Site available at: http://$name.local"
    else
        echo "Configuration error - rolling back"
        sudo mv "$backup" /etc/caddy/Caddyfile
        return 1
    fi
}

list-sites() {
    if [ -f "/etc/caddy/Caddyfile" ]; then
        sudo grep -E "^[a-zA-Z0-9.-]+(.local)?(:[0-9]+)? {" /etc/caddy/Caddyfile 2>/dev/null | sed 's/ {//' || echo "No sites configured"
    else
        echo "No Caddyfile found"
    fi
}

remove-site() {
    if [ -z "$1" ]; then
        echo "Usage: remove-site <name>"
        return 1
    fi

    local name=$1
    local backup="/etc/caddy/Caddyfile.backup.$(date +%Y%m%d_%H%M%S)"

    sudo cp /etc/caddy/Caddyfile "$backup"
    sudo sed -i "/^$name\.local:80 {/,/^}/d" /etc/caddy/Caddyfile

    if caddy validate --config /etc/caddy/Caddyfile 2>/dev/null; then
        sudo systemctl reload caddy
        echo "Removed $name.local from Caddy"
    else
        echo "Configuration error - rolling back"
        sudo mv "$backup" /etc/caddy/Caddyfile
        return 1
    fi
}

test-caddy() {
    caddy validate --config /etc/caddy/Caddyfile
}

caddy-status() {
    sudo systemctl status caddy --no-pager
    echo
    sudo journalctl -u caddy --no-pager -n 10
}

# ----- PM2 management -----

pm2-start() {
    if [ -z "$1" ]; then
        echo "Usage: pm2-start <ecosystem-file>"
        return 1
    fi
    if [ ! -f "$1" ]; then
        echo "Ecosystem file $1 not found"
        return 1
    fi
    pm2 start "$1"
    pm2 list
}

pm2-add-site() {
    if [ -z "$1" ] || [ -z "$2" ] || [ -z "$3" ]; then
        echo "Usage: pm2-add-site <name> <port> <ecosystem-file>"
        return 1
    fi
    pm2-start "$3"
    add-site "$1" "$2"
}

pm2-remove() {
    if [ -z "$1" ]; then
        echo "Usage: pm2-remove <name>"
        return 1
    fi
    pm2 stop "$1" 2>/dev/null || true
    pm2 delete "$1" 2>/dev/null || true
}

pm2-restart() {
    if [ -z "$1" ]; then
        echo "Usage: pm2-restart <name>"
        return 1
    fi
    pm2 restart "$1"
    pm2 list
}

pm2-logs() {
    if [ -z "$1" ]; then
        echo "Usage: pm2-logs <name>"
        return 1
    fi
    pm2 logs "$1"
}

pm2-status() {
    pm2 list
    echo
    list-sites
}

# ----- System status helpers -----

system-status() {
    echo "Uptime: $(uptime -p)"
    echo "Load:   $(uptime | awk -F'load average:' '{print $2}')"
    echo "Memory: $(free -h | awk '/^Mem:/ {print $3 "/" $2}')"
    echo "Disk:   $(df -h / | awk 'NR==2 {print $3 "/" $2 " (" $5 " used)"}')"
    echo
    echo "=== Top processes ==="
    ps aux --sort=-%cpu | head -10
    echo
    echo "=== Listening ==="
    ss -tulpn | grep LISTEN | head -10
}

db-status() {
    echo "=== PostgreSQL ==="
    sudo systemctl status postgresql --no-pager
    echo
    echo "=== Valkey ==="
    sudo systemctl status valkey --no-pager
    echo
    psql -c "SELECT count(*) AS connections FROM pg_stat_activity;" 2>/dev/null || echo "PostgreSQL not accessible"
    valkey-cli info clients 2>/dev/null | grep connected_clients || echo "Valkey not accessible"
}

security-status() {
    echo "=== UFW ==="
    sudo ufw status verbose
    echo
    echo "=== Fail2ban ==="
    sudo fail2ban-client status
    echo
    echo "=== SSH ==="
    sudo systemctl status sshd --no-pager
    echo
    sudo journalctl -u sshd --no-pager -n 10
}

port-check() {
    if [ -z "$1" ]; then
        echo "Usage: port-check <port>"
        return 1
    fi
    if lsof -i ":$1" >/dev/null 2>&1; then
        echo "Port $1 in use:"
        lsof -i ":$1"
    else
        echo "Port $1 is available"
    fi
}

# ----- VS Code Server management -----

vscode-status() {
    sudo systemctl status code-server@$USER --no-pager
    echo
    sudo journalctl -u code-server@$USER --no-pager -n 10
    echo
    echo "Access at: http://vscode.local"
    if [ -f "$HOME/.config/code-server/config.yaml" ]; then
        echo "Password:  $(grep '^password:' "$HOME/.config/code-server/config.yaml" | awk '{print $2}')"
    fi
}

vscode-restart() {
    sudo systemctl restart code-server@$USER
    vscode-status
}

vscode-logs() {
    sudo journalctl -u code-server@$USER -f
}

vscode-password() {
    if [ -f "$HOME/.config/code-server/config.yaml" ]; then
        echo "Password: $(grep '^password:' "$HOME/.config/code-server/config.yaml" | awk '{print $2}')"
        echo "URL:      http://vscode.local"
    fi
}

vscode-change-password() {
    if [ -z "$1" ]; then
        echo "Usage: vscode-change-password <new-password>"
        return 1
    fi
    sed -i "s/^password: .*/password: $1/" "$HOME/.config/code-server/config.yaml"
    sudo systemctl restart code-server@$USER
    echo "Password updated"
}

# ----- Backup -----

backup-system() {
    local dir="$HOME/backups/$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$dir"
    sudo cp -r /etc/caddy /etc/ssh /etc/ufw /etc/fail2ban "$dir/" 2>/dev/null || true
    cp -r ~/.zshrc ~/.tmux.conf ~/.config "$dir/" 2>/dev/null || true
    sudo chown -R "$USER:$USER" "$dir"
    echo "Backup: $dir"
}

# ----- Project scaffolding -----

create-react-hono() {
    if [ -z "$1" ]; then
        echo "Usage: create-react-hono <project-name>"
        return 1
    fi

    local name=$1
    local dir="$HOME/projects/$name"

    mkdir -p "$dir"
    cd "$dir" || return 1

    npm init -y
    npm install hono @hono/node-server react react-dom
    npm install -D @types/node @types/react @types/react-dom typescript tsx vite @vitejs/plugin-react concurrently

    mkdir -p src/{client,server}

    cat > src/server/index.ts << 'HONO'
import { Hono } from 'hono'
import { serve } from '@hono/node-server'

const app = new Hono()

app.get('/', (c) => c.json({ message: 'Hello Hono!' }))
app.get('/api/health', (c) => c.json({ status: 'ok', timestamp: new Date().toISOString() }))

serve({ fetch: app.fetch, port: 3000 })
console.log('Server running on port 3000')
HONO

    cat > src/client/App.tsx << 'REACT'
export default function App() {
  return <div><h1>React + Hono</h1></div>
}
REACT

    cat > vite.config.ts << 'VITE'
import { defineConfig } from 'vite'
import react from '@vitejs/plugin-react'

export default defineConfig({
  plugins: [react()],
  server: { proxy: { '/api': 'http://localhost:3000' } }
})
VITE

    echo "Created $dir"
    echo "Next: cd $dir && npm run dev && add-site $name 3000"
}

