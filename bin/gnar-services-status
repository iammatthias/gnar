#!/bin/bash
# GNAR — service + Caddy-site health for the dashboard pane.
#
# Host services run via systemd. The container stack (caddy + tailscale +
# hermes-gateway + hermes-dashboard) lives under /srv/stack and is reported
# via `docker compose ps`.

set -uo pipefail

dot() {
    case "$1" in
        active|up|running|ok)   printf '\033[32m●\033[0m' ;;
        inactive|down|failed|exited|unknown) printf '\033[31m●\033[0m' ;;
        *)                      printf '\033[33m●\033[0m' ;;
    esac
}

printf '\033[1;36m═══ Host services ═══\033[0m\n'
for svc in docker postgresql valkey fail2ban ufw gnar-stack; do
    state=$(systemctl is-active "$svc" 2>/dev/null) || true
    state=${state:-unknown}
    printf '  '; dot "$state"; printf ' %-26s %s\n' "$svc" "$state"
done

# fail2ban — show currently banned count, useful at a glance.
if systemctl is-active --quiet fail2ban; then
    banned=$(fail2ban-client status sshd 2>/dev/null \
        | awk -F'[ \t]+' '/Currently banned/ {print $NF}')
    [ -n "$banned" ] && printf '  fail2ban (sshd): %s currently banned\n' "$banned"
fi

echo
printf '\033[1;36m═══ Container stack ═══\033[0m\n'
if [ -f /srv/stack/docker-compose.yml ] && command -v docker &>/dev/null; then
    docker compose -f /srv/stack/docker-compose.yml ps --format \
        '{{.Service}}\t{{.State}}\t{{.Status}}' 2>/dev/null \
      | while IFS=$'\t' read -r svc state status; do
            [ -z "$svc" ] && continue
            printf '  '; dot "$state"; printf ' %-22s %s\n' "$svc" "$status"
        done
else
    echo '  (no /srv/stack/docker-compose.yml or docker not installed)'
fi

echo
printf '\033[1;36m═══ Caddy sites ═══\033[0m\n'
CADDYFILE=/srv/stack/Caddyfile
PREVIEW_HANDLES=/srv/stack/preview-handles

# Three site flavors, each stored differently:
#   private  — `<name>.local:80 {` blocks in the Caddyfile (add-site)
#   public   — `http://<host>:8080 {` blocks in the Caddyfile (add-public-site)
#   preview  — fragment files under preview-handles/, NOT in the Caddyfile
#              (add-preview-site); imported into the wildcard HTTPS block.
sites=()

if [ -f "$CADDYFILE" ]; then
    while read -r host; do
        [ -n "$host" ] && sites+=("http://$host")
    done < <(grep -E '^[a-zA-Z0-9.-]+\.local:80 \{' "$CADDYFILE" 2>/dev/null \
        | sed 's/:80 {$//')
    while read -r host; do
        [ -n "$host" ] && sites+=("https://$host (public)")
    done < <(grep -E '^http://[a-zA-Z0-9.-]+:8080 \{' "$CADDYFILE" 2>/dev/null \
        | sed 's|^http://||;s|:8080 {$||')
fi

if [ -d "$PREVIEW_HANDLES" ]; then
    apex=$(awk -F= '/^PREVIEW_APEX=/{print $2}' /srv/stack/.env 2>/dev/null \
        | tr -d "\"' ")
    apex=${apex:-previews.example.com}
    for f in "$PREVIEW_HANDLES"/*.caddy; do
        [ -e "$f" ] || continue
        name=$(basename "$f" .caddy)
        sites+=("https://$name.$apex (preview)")
    done
fi

if [ ! -f "$CADDYFILE" ]; then
    echo "  (no $CADDYFILE)"
elif [ ${#sites[@]} -eq 0 ]; then
    echo '  (none)'
else
    for site in "${sites[@]}"; do
        printf '  '; dot ok; printf ' %s\n' "$site"
    done
fi
