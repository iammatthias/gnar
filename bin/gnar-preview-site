#!/bin/bash
# GNAR — spin up a static preview site on its own tailnet hostname.
#
# Pattern: per-site tailscale sidecar. Each preview gets its own tailnet
# node, so you get a real MagicDNS hostname (https://<name>.<tailnet>.ts.net)
# without any tags, ACL grants, or svc:foo wiring. The cost is one
# tailscale + one caddy container per preview (each tiny).
#
# Usage:
#   gnar-preview-site <name> <site_dir>
#   TS_AUTHKEY=tskey-auth-... gnar-preview-site <name> <site_dir>
#   gnar-preview-site --remove <name>
#   gnar-preview-site --list
#
# Generate auth keys at:
#   https://login.tailscale.com/admin/settings/keys
# Reusable + ephemeral both fine. No tags required.

set -euo pipefail

ROOT=/srv/preview-sites
TEMPLATE=/srv/stack/preview-site

usage() {
    sed -n '3,17p' "$0" | sed 's/^# \{0,1\}//'
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

# ---- list -----------------------------------------------------------------
if [ "$1" = "--list" ]; then
    if [ ! -d "$ROOT" ] || [ -z "$(ls -A "$ROOT" 2>/dev/null)" ]; then
        echo "No preview sites."
        exit 0
    fi
    for site in "$ROOT"/*/; do
        name=$(basename "$site")
        running=$(docker ps --filter "name=gnar-preview-${name}-tailscale" \
            --format '{{.Status}}' 2>/dev/null || echo "not running")
        domain=$(docker exec "gnar-preview-${name}-tailscale" \
            tailscale status --json 2>/dev/null \
            | jq -r '.MagicDNSSuffix // empty' 2>/dev/null || true)
        if [ -n "$domain" ]; then
            url="https://${name}.${domain}"
        else
            url='(not authenticated yet)'
        fi
        printf '%-20s  %-30s  %s\n' "$name" "$url" "$running"
    done
    exit 0
fi

# ---- remove ---------------------------------------------------------------
if [ "$1" = "--remove" ]; then
    NAME=${2:-}
    [ -n "$NAME" ] || { echo "Usage: gnar-preview-site --remove <name>"; exit 1; }
    if [ ! -d "$ROOT/$NAME" ]; then
        echo "No preview at $ROOT/$NAME"
        exit 1
    fi
    cd "$ROOT/$NAME"
    sudo docker compose -p "preview-$NAME" down -v 2>/dev/null || true
    cd /
    sudo rm -rf "$ROOT/$NAME"
    echo "Removed preview: $NAME"
    echo "Note: the tailnet still has a record for this node — delete it"
    echo "from https://login.tailscale.com/admin/machines if you want."
    exit 0
fi

# ---- create ---------------------------------------------------------------
NAME=$1
SITE_DIR=${2:-}
[ -n "$SITE_DIR" ] || usage

[ -d "$SITE_DIR" ] || { echo "Site directory '$SITE_DIR' does not exist"; exit 1; }
[ -d "$TEMPLATE" ] || { echo "Template $TEMPLATE missing — pull latest gnar and re-run setup.sh"; exit 1; }

# Sanitize name (DNS label).
case "$NAME" in
    *[!a-z0-9-]*|-*|*-) echo "Name must match [a-z0-9-]+, no leading/trailing dash"; exit 1 ;;
esac

SITE_DIR=$(readlink -f "$SITE_DIR")

if [ -z "${TS_AUTHKEY:-}" ]; then
    echo "Need a tailscale auth key for this preview node."
    echo "Generate one at: https://login.tailscale.com/admin/settings/keys"
    echo "  (reusable OK, ephemeral OK, no tags required)"
    read -r -s -p "TS_AUTHKEY: " TS_AUTHKEY
    echo
fi
[ -n "$TS_AUTHKEY" ] || { echo "No auth key — aborting"; exit 1; }

sudo mkdir -p "$ROOT/$NAME/data/tailscale"
sudo cp "$TEMPLATE/docker-compose.yml" "$ROOT/$NAME/docker-compose.yml"
sudo cp "$TEMPLATE/Caddyfile"          "$ROOT/$NAME/Caddyfile"

sudo tee "$ROOT/$NAME/.env" > /dev/null <<EOF
NAME=$NAME
TS_AUTHKEY=$TS_AUTHKEY
SITE_DIR=$SITE_DIR
EOF
sudo chmod 600 "$ROOT/$NAME/.env"

cd "$ROOT/$NAME"
sudo docker compose -p "preview-$NAME" up -d

# Look up tailnet domain from the main gnar tailscale container; all nodes
# in the tailnet share the same suffix.
DOMAIN=$(sudo docker exec gnar-tailscale tailscale status --json 2>/dev/null \
    | jq -r '.MagicDNSSuffix // empty' 2>/dev/null || true)
[ -n "$DOMAIN" ] || DOMAIN='<tailnet>.ts.net'

echo
echo "  https://${NAME}.${DOMAIN}"
echo
echo "  (give it ~30s for the node to register + cert to issue)"
echo
echo "Manage:  cd $ROOT/$NAME && sudo docker compose -p preview-$NAME logs -f"
echo "List:    gnar-preview-site --list"
echo "Remove:  gnar-preview-site --remove $NAME"
