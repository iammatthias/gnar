#!/bin/bash
# GNAR — tmux dashboard: the ssh view of gnar-board.
#
# One full-screen pane running `gnar-board` (full-board mode): host
# CPU/MEM/NET/DISK graphs, per-container sparklines, and stack status,
# all diff-rendered so nothing flickers. The kiosk display doesn't use
# this — mango composites six single-panel gnar-board tiles in a grid
# (see configs/mango-config.conf); this tmux session is for looking at
# the same board over ssh, where there's no compositor.
#
# Fallback (gnar-board not built — cargo missing at setup time): the
# original btop + shell-board split, with buffered repaints to keep the
# flicker down.
#
# `gnar-claude-stats` still exists as a one-shot — run it manually if you
# want a snapshot of Claude Code activity. Hermes is the day-to-day signal.
#
# Auto-attaches if the session already exists. Without a tty (e.g. over
# plain ssh) it creates/refreshes the session detached.

set -uo pipefail

SESSION=dashboard

# Already running? Just attach.
if tmux has-session -t "$SESSION" 2>/dev/null; then
    [ -t 0 ] && exec tmux attach -t "$SESSION"
    exit 0
fi

# Build a self-refreshing pane command for the fallback shell boards:
# render to a buffer first, then home+clear+paint in a single printf —
# no blank frame between refreshes. `while :;` means a transient
# command failure never tears the pane down.
loop() {  # loop <interval-seconds> <command>
    printf 'while :; do out=$(%s 2>&1); printf "\\033[H\\033[2J%%s\\n" "$out"; sleep %s; done' "$2" "$1"
}

if command -v gnar-board >/dev/null 2>&1; then
    # Full-screen ratatui board. The respawn loop means a crash never
    # leaves a dead kiosk pane.
    tmux new-session -d -s "$SESSION" -n main -x "${COLUMNS:-232}" -y "${LINES:-55}" \
        'while :; do gnar-board; sleep 2; done'
else
    # Fallback: btop + the shell boards.
    tmux new-session -d -s "$SESSION" -n main -x "${COLUMNS:-232}" -y "${LINES:-55}" 'btop'
    tmux split-window -v -t "$SESSION:main" -l 44% "$(loop 10 gnar-metrics-board)"
    tmux split-window -h -t "$SESSION:main.{bottom-left}" -l 50% "$(loop 30 gnar-status-board)"
    tmux select-pane  -t "$SESSION:main.{top-left}"
fi
tmux set-option   -t "$SESSION" status off
tmux set-option   -t "$SESSION" mouse on

[ -t 0 ] && exec tmux attach -t "$SESSION"
exit 0
