# GNAR — auto-start mango on tty1 when a display is actually plugged in.
#
# Headless boxes never reach mango: the DRM-status check below short-
# circuits when no monitor is connected. Plug a display into the server
# and on next login this exec-launches the kiosk dashboard.
#
# The layout (mango grid) fills whatever screen is attached; here we only
# scale the FONT to the resolution so tile density stays legible — small
# rack LCD gets a smaller font, a desk monitor a larger one.
if [ -z "$DISPLAY$WAYLAND_DISPLAY" ] && [ "$(tty)" = "/dev/tty1" ] && command -v mango &>/dev/null; then
    for _drm_status in /sys/class/drm/*/status; do
        [ -r "$_drm_status" ] || continue
        [ "$(cat "$_drm_status")" = "connected" ] || continue

        # Preferred mode is the first line of the output's modes file (WxH).
        _drm_dir="${_drm_status%/status}"
        _mode="$(head -n1 "$_drm_dir/modes" 2>/dev/null)"
        _width="${_mode%x*}"
        case "$_width" in '' | *[!0-9]*) _width=2560 ;; esac

        if [ "$_width" -le 1366 ]; then
            _size=10            # rack / small touch LCD
        elif [ "$_width" -le 1920 ]; then
            _size=12
        else
            _size=14            # desk monitor
        fi
        export GNAR_KIOSK_FONT="JetBrainsMono Nerd Font:size=$_size"

        # Pointer present? A touchscreen (rack LCD) or a mouse both mean the
        # user can operate the on-screen action buttons, so gnar-board shows
        # them. udev tags devices ID_INPUT_TOUCHSCREEN / ID_INPUT_MOUSE.
        GNAR_TOUCH=
        for _ev in /sys/class/input/event*; do
            [ -e "$_ev" ] || continue
            _p="$(udevadm info -q property -p "$_ev" 2>/dev/null)"
            case "$_p" in
                *ID_INPUT_TOUCHSCREEN=1* | *ID_INPUT_MOUSE=1*) GNAR_TOUCH=1; break ;;
            esac
        done
        export GNAR_TOUCH

        exec mango -c "$HOME/.config/mango/config.conf"
    done
fi
