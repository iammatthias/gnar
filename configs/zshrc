# ----- Caddy site management (Caddy runs in /srv/stack) -----
#
# Two listeners:
#   :80   — private vhosts (tailnet only). Use add-site.
#   :8080 — public vhosts (Cloudflare Tunnel target). Use add-public-site.

GNAR_CADDYFILE=/srv/stack/Caddyfile
# Use -f to point compose at the file directly so `sudo $GNAR_CADDY_RELOAD`
# is a single command — `sudo cd ...` fails because cd is a shell builtin.
GNAR_CADDY_RELOAD='docker compose -f /srv/stack/docker-compose.yml exec -T caddy caddy reload --config /etc/caddy/Caddyfile'

# Append text right after a marker line and reload caddy. Rolls back on
# invalid config.
_gnar_caddy_append() {
    local marker=$1
    local block=$2
    local backup="$GNAR_CADDYFILE.backup.$(date +%Y%m%d_%H%M%S)"

    sudo cp "$GNAR_CADDYFILE" "$backup"
    # Insert the new block right after the marker, separated by a blank line.
    printf '%s\n' "$block" | sudo tee -a "$GNAR_CADDYFILE" > /dev/null

    if eval "sudo $GNAR_CADDY_RELOAD" 2>/dev/null; then
        return 0
    else
        echo "Caddy reload failed — rolling back"
        sudo mv "$backup" "$GNAR_CADDYFILE"
        return 1
    fi
}

# --- Private vhost on :80 (tailnet) -----------------------------------------
add-site() {
    if [ -z "$1" ]; then
        echo "Usage: add-site <name> [port|directory]"
        echo "Examples:"
        echo "  add-site myapp 3000              # reverse proxy http://myapp.local → host:3000"
        echo "  add-site static /srv/projects/x  # serve static dir"
        echo "Tailnet only. For public sites, use add-public-site."
        return 1
    fi

    local name=$1
    local target=${2:-3000}

    # Drop any existing block for this name (private).
    if sudo grep -q "^$name\.local:80 {" "$GNAR_CADDYFILE" 2>/dev/null; then
        sudo sed -i "/^$name\.local:80 {/,/^}/d" "$GNAR_CADDYFILE"
    fi

    local block
    if [[ "$target" =~ ^[0-9]+$ ]]; then
        block=$(printf '\n# private: %s\n%s.local:80 {\n    reverse_proxy host.docker.internal:%s\n}' \
            "$name" "$name" "$target")
        _gnar_caddy_append PRIVATE-SITES "$block" \
            && echo "Private site: http://$name.local → host:$target"
    else
        if [ ! -d "$target" ]; then
            echo "Directory $target does not exist"
            return 1
        fi
        block=$(printf '\n# private static: %s\n%s.local:80 {\n    root * %s\n    file_server\n}' \
            "$name" "$name" "$target")
        _gnar_caddy_append PRIVATE-SITES "$block" \
            && echo "Private static: http://$name.local → $target"
        echo "Note: $target must be bind-mounted into the caddy container (edit /srv/stack/docker-compose.yml)."
    fi
}

# --- Public vhost on :8080 (Cloudflare Tunnel) ------------------------------
add-public-site() {
    if [ -z "$1" ]; then
        echo "Usage: add-public-site <hostname> [port|directory]"
        echo "Examples:"
        echo "  add-public-site myapp.example.com 3000"
        echo "  add-public-site blog.example.com /srv/projects/blog/public"
        echo "Public via cloudflared. You also need to (a) configure the public"
        echo "hostname → http://localhost:8080 route in the Cloudflare dashboard,"
        echo "and (b) point DNS at the tunnel."
        return 1
    fi

    local host=$1
    local target=${2:-3000}

    # Drop any existing block for this host (public listener uses :8080).
    if sudo grep -q "^http://$host:8080 {" "$GNAR_CADDYFILE" 2>/dev/null; then
        sudo sed -i "/^http:\/\/$host:8080 {/,/^}/d" "$GNAR_CADDYFILE"
    fi

    local block
    if [[ "$target" =~ ^[0-9]+$ ]]; then
        block=$(printf '\n# public: %s\nhttp://%s:8080 {\n    reverse_proxy host.docker.internal:%s\n}' \
            "$host" "$host" "$target")
        _gnar_caddy_append PUBLIC-SITES "$block" \
            && echo "Public site: https://$host → host:$target (via tunnel)"
    else
        if [ ! -d "$target" ]; then
            echo "Directory $target does not exist"
            return 1
        fi
        block=$(printf '\n# public static: %s\nhttp://%s:8080 {\n    root * %s\n    file_server\n}' \
            "$host" "$host" "$target")
        _gnar_caddy_append PUBLIC-SITES "$block" \
            && echo "Public static: https://$host → $target (via tunnel)"
        echo "Note: $target must be bind-mounted into the caddy container (edit /srv/stack/docker-compose.yml)."
    fi
}

# --- Preview vhost on the *.$PREVIEW_APEX wildcard (tailnet-private) -------
# Convention: every preview gets <name>.$PREVIEW_APEX, served by caddy with
# a real LE wildcard cert (DNS-01 via Cloudflare). Tailnet-private because
# *.$PREVIEW_APEX DNS resolves to this box's tailnet IP.
#
# Each preview is one fragment file under /srv/stack/preview-handles/<name>.caddy
# imported into the wildcard HTTPS block in /srv/stack/Caddyfile.
GNAR_PREVIEW_HANDLES=/srv/stack/preview-handles

_gnar_preview_apex() {
    local apex
    apex=$(awk -F= '/^PREVIEW_APEX=/{print $2}' /srv/stack/.env 2>/dev/null \
        | tr -d "\"' ")
    printf '%s' "${apex:-previews.example.com}"
}

add-preview-site() {
    if [ -z "$1" ]; then
        local apex; apex=$(_gnar_preview_apex)
        echo "Usage: add-preview-site <name> [port|directory]"
        echo "Examples:"
        echo "  add-preview-site hello /srv/projects/hello-world"
        echo "  add-preview-site myapp 3000"
        echo "Visible at: https://<name>.$apex (tailnet-private)"
        echo "PREVIEW_APEX is read from /srv/stack/.env."
        return 1
    fi

    local name=$1
    local target=${2:-3000}
    local apex
    apex=$(_gnar_preview_apex)
    local host="$name.$apex"
    local handle_file="$GNAR_PREVIEW_HANDLES/$name.caddy"
    local backup_file=""

    sudo mkdir -p "$GNAR_PREVIEW_HANDLES"
    if sudo test -f "$handle_file"; then
        backup_file="$handle_file.backup.$(date +%Y%m%d_%H%M%S)"
        sudo cp "$handle_file" "$backup_file"
    fi

    if [[ "$target" =~ ^[0-9]+$ ]]; then
        sudo tee "$handle_file" > /dev/null <<EOF
# preview: $name → host:$target
@$name host $host
handle @$name {
    reverse_proxy host.docker.internal:$target
}
EOF
    else
        if [ ! -d "$target" ]; then
            echo "Directory $target does not exist"
            return 1
        fi
        sudo tee "$handle_file" > /dev/null <<EOF
# preview static: $name → $target
@$name host $host
handle @$name {
    root * $target
    file_server
}
EOF
    fi

    if eval "sudo $GNAR_CADDY_RELOAD"; then
        echo "Preview: https://$host → $target"
        [ -n "$backup_file" ] && sudo rm -f "$backup_file"
        return 0
    else
        echo "Caddy reload failed — rolling back"
        if [ -n "$backup_file" ]; then
            sudo mv "$backup_file" "$handle_file"
        else
            sudo rm -f "$handle_file"
        fi
        return 1
    fi
}

remove-preview-site() {
    if [ -z "$1" ]; then
        echo "Usage: remove-preview-site <name>"
        return 1
    fi
    local handle_file="$GNAR_PREVIEW_HANDLES/$1.caddy"
    if ! sudo test -f "$handle_file"; then
        echo "No preview at $handle_file"
        return 1
    fi
    sudo rm -f "$handle_file"
    eval "sudo $GNAR_CADDY_RELOAD" && echo "Removed preview: $1"
}

list-preview-sites() {
    local apex; apex=$(_gnar_preview_apex)
    if ! sudo test -d "$GNAR_PREVIEW_HANDLES"; then
        echo "No previews."
        return
    fi
    for f in $(sudo find "$GNAR_PREVIEW_HANDLES" -maxdepth 1 -name '*.caddy' 2>/dev/null); do
        local name; name=$(basename "$f" .caddy)
        printf "  https://%s.%s\n" "$name" "$apex"
    done
}

list-sites() {
    if [ ! -f "$GNAR_CADDYFILE" ]; then
        echo "No Caddyfile at $GNAR_CADDYFILE"
        return
    fi
    echo "Private (tailnet):"
    sudo grep -E "^[a-zA-Z0-9.-]+\.local:80 \{" "$GNAR_CADDYFILE" 2>/dev/null \
        | sed 's/ {//;s/^/  /' || echo "  (none)"
    echo "Public (cloudflared):"
    sudo grep -E "^http://[a-zA-Z0-9.-]+:8080 \{" "$GNAR_CADDYFILE" 2>/dev/null \
        | sed 's| {||;s|^http://|  |' || echo "  (none)"
}

remove-site() {
    if [ -z "$1" ]; then
        echo "Usage: remove-site <name-or-hostname>"
        echo "Matches both private (.local:80) and public (:8080) blocks."
        return 1
    fi

    local name=$1
    local backup="$GNAR_CADDYFILE.backup.$(date +%Y%m%d_%H%M%S)"
    sudo cp "$GNAR_CADDYFILE" "$backup"
    sudo sed -i "/^$name\.local:80 {/,/^}/d" "$GNAR_CADDYFILE"
    sudo sed -i "/^http:\/\/$name:8080 {/,/^}/d" "$GNAR_CADDYFILE"
    # Note: preview subdomains live in /srv/stack/preview-handles/<name>.caddy,
    # not in the Caddyfile. Use `remove-preview-site` for those.

    if eval "sudo $GNAR_CADDY_RELOAD" 2>/dev/null; then
        echo "Removed $name from Caddy"
    else
        echo "Configuration error — rolling back"
        sudo mv "$backup" "$GNAR_CADDYFILE"
        return 1
    fi
}

