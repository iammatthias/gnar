#!/bin/bash
# GNAR — spawn the six kiosk dashboard tiles in deterministic order.
#
# Launched by mango's exec-once (see configs/mango-config.conf).
# Placement is pinned per-appid by the mosaic windowrules, so spawn
# order doesn't matter there — but the grid fallback (rules removed)
# fills row-major in client order, and six parallel foot launches map
# nondeterministically. Launching one at a time with a beat between
# keeps the fallback order deterministic:
#
#   CPU   MEM         NET
#   DISK  CONTAINERS  STATUS
#
# Each tile runs `gnar-board <panel>` in a respawn loop so a crash
# never leaves a hole in the mosaic. (The status tile renders the
# HERMES panel on the kiosk.)

set -u

# Small displays (set by ~/.zprofile) override the foot font so the compact
# grid tiles stay legible; unset → foot.ini's default.
font_args=()
[ -n "${GNAR_KIOSK_FONT:-}" ] && font_args=(--font="$GNAR_KIOSK_FONT")

for panel in cpu mem net disk containers status; do
    foot --app-id="gnar-$panel" "${font_args[@]}" \
         -e sh -c "while :; do gnar-board $panel; sleep 2; done" &
    sleep 0.5
done
wait
