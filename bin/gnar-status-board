#!/bin/bash
# GNAR — unified status board: the kiosk dashboard's lower pane.
#
# One renderer laying host services, containers and Caddy sites into
# three aligned columns, with a Hermes summary line beneath. btop owns
# the upper pane. A grid — rather than three stacked lists in three
# tmux panes — so a wide display reads at a glance instead of feeling
# cramped, and there are no pane seams to clash.
#
# Self-refreshes from gnar-dashboard's pane loop; also runs one-shot.
# Columns size to the terminal width, so it adapts to any pane size.

set -uo pipefail

RST=$'\033[0m'; BOLD=$'\033[1m'; DIM=$'\033[2m'
CYAN=$'\033[36m'; GREEN=$'\033[32m'; RED=$'\033[31m'; YEL=$'\033[33m'
US=$'\x1f'   # field separator inside gathered entries

dotcolor() {
    case "$1" in
        active|running|ok|up)             printf '%s' "$GREEN" ;;
        inactive|failed|exited|dead|down) printf '%s' "$RED" ;;
        *)                                printf '%s' "$YEL" ;;
    esac
}

# "3 days" -> "3d", "31 minutes" -> "31m". Leaves unparseable forms
# ("About a minute") as-is.
compact_age() {
    local num=${1%% *} unit=${1#* }
    case "$unit" in
        sec*)  unit=s  ;; min*)  unit=m ;; hour*) unit=h ;;
        day*)  unit=d  ;; week*) unit=w ;; month*) unit=mo ;;
        year*) unit=y  ;;
        *)     printf '%s' "$1"; return ;;
    esac
    printf '%s%s' "$num" "$unit"
}

# Hermes lives in the container stack — summarise it in one line.
hermes_summary() {
    local cf=/srv/stack/docker-compose.yml
    if [ ! -f "$cf" ]; then
        printf '%s(stack not deployed)%s' "$DIM" "$RST"
        return
    fi
    local C="docker compose -f $cf"
    local state
    state=$($C ps --format '{{.Service}} {{.State}}' 2>/dev/null \
            | awk '$1=="hermes-gateway"{print $2}')
    if [ "${state:-}" != running ]; then
        printf '%s●%s gateway %s' "$RED" "$RST" "${state:-down}"
        return
    fi
    printf '%s●%s gateway up' "$GREEN" "$RST"
    # Best-effort detail — the in-container hermes CLI may not answer.
    local E="$C exec -T hermes-gateway" k cr
    k=$($E hermes kanban list 2>/dev/null | grep -c '[^[:space:]]' || true)
    cr=$($E hermes cron list 2>/dev/null | grep -c '[^[:space:]]' || true)
    [ "${k:-0}" -gt 0 ] 2>/dev/null  && printf '%s   kanban %s%s' "$DIM" "$k"  "$RST"
    [ "${cr:-0}" -gt 0 ] 2>/dev/null && printf '%s   cron %s%s'   "$DIM" "$cr" "$RST"
    backup_summary
}

# Age of the newest nightly Hermes backup. The backup cron's watchdog
# pattern only signals on failure — a cron that never fired leaves no
# trace, so surface staleness here (red past 36h ≈ one missed nightly).
backup_summary() {
    local newest
    newest=$(ls -1t /srv/stack/data/backups/hermes-backup-*.zip 2>/dev/null | head -1)
    [ -z "$newest" ] && return
    local age=$(( ($(date +%s) - $(stat -c %Y "$newest")) / 3600 ))
    if [ "$age" -gt 36 ]; then
        printf '   %s● backup %sh old%s' "$RED" "$age" "$RST"
    else
        printf '%s   backup %sh%s' "$DIM" "$age" "$RST"
    fi
}

# --- geometry --------------------------------------------------------------
# Three fixed-width columns with a generous gap between them, the whole
# block centred. Columns stay a compact, readable width on a wide kiosk
# display (rather than stretching to fill, which strands the status
# value far from its name) and shrink to fit a narrow terminal.
cols=$(tput cols 2>/dev/null || echo 120)
metaw=9
gapmin=3; gapmax=24
cellw=40                                          # preferred column width
maxcell=$(( (cols - 4 - 2 * gapmin) / 3 ))
[ "$cellw" -gt "$maxcell" ] && cellw=$maxcell
[ "$cellw" -lt 22 ] && cellw=22
namew=$(( cellw - 2 - metaw ))
[ "$namew" -lt 8 ] && namew=8
gap=$(( (cols - 4 - 3 * cellw) / 2 ))
[ "$gap" -gt "$gapmax" ] && gap=$gapmax
[ "$gap" -lt "$gapmin" ] && gap=$gapmin
leftpad=$(( (cols - (3 * cellw + 2 * gap)) / 2 ))
[ "$leftpad" -lt 2 ] && leftpad=2

# --- gather: host services -------------------------------------------------
c1=()
for s in docker postgresql valkey fail2ban ufw gnar-stack; do
    st=$(systemctl is-active "$s" 2>/dev/null || true)
    st=${st:-unknown}
    c1+=( "${st}${US}${s}${US}${st}" )
done

# --- gather: containers ----------------------------------------------------
c2=()
if systemctl is-active --quiet docker; then
    while IFS=$'\t' read -r name status; do
        [ -z "$name" ] && continue
        status=${status#Up }       # "Up 3 days" -> "3 days"
        status=${status%% (*}      # drop "(healthy)" etc.
        c2+=( "running${US}${name}${US}$(compact_age "$status")" )
    done < <(docker ps --format '{{.Names}}\t{{.Status}}' 2>/dev/null | sort)
fi
[ ${#c2[@]} -eq 0 ] && c2=( "down${US}(no containers)${US}" )

# --- gather: caddy sites ---------------------------------------------------
c3=()
CADDYFILE=/srv/stack/Caddyfile
PREVIEW_HANDLES=/srv/stack/preview-handles
if [ -f "$CADDYFILE" ]; then
    while read -r h; do
        [ -n "$h" ] && c3+=( "ok${US}${h}${US}private" )
    done < <(grep -E '^[a-zA-Z0-9.-]+\.local:80 \{' "$CADDYFILE" 2>/dev/null \
             | sed 's/:80 {$//')
    while read -r h; do
        [ -n "$h" ] && c3+=( "ok${US}${h}${US}public" )
    done < <(grep -E '^http://[a-zA-Z0-9.-]+:8080 \{' "$CADDYFILE" 2>/dev/null \
             | sed 's|^http://||;s|:8080 {$||')
fi
if [ -d "$PREVIEW_HANDLES" ]; then
    apex=$(awk -F= '/^PREVIEW_APEX=/{print $2}' /srv/stack/.env 2>/dev/null \
           | tr -d "\"' ")
    apex=${apex:-previews.example.com}
    for f in "$PREVIEW_HANDLES"/*.caddy; do
        [ -e "$f" ] || continue
        c3+=( "ok${US}$(basename "$f" .caddy).${apex}${US}preview" )
    done
fi
[ ${#c3[@]} -eq 0 ] && c3=( "unknown${US}(no sites)${US}" )

# --- render ----------------------------------------------------------------
pad() { printf '%*s' "$1" ''; }

header() { printf '%s%s%-*s%s' "$BOLD" "$CYAN" "$cellw" "$1" "$RST"; }

rendercell() {  # rendercell <entry-or-empty>
    local entry=$1
    if [ -z "$entry" ]; then pad "$cellw"; return; fi
    local state=${entry%%"${US}"*}
    local rest=${entry#*"${US}"}
    local name=${rest%%"${US}"*}
    local meta=${rest#*"${US}"}
    printf '%s●%s %-*s%s%-*s%s' \
        "$(dotcolor "$state")" "$RST" \
        "$namew" "${name:0:namew}" \
        "$DIM" "$metaw" "${meta:0:metaw}" "$RST"
}

row() {  # row <entry1> <entry2> <entry3>
    pad "$leftpad"
    rendercell "${1:-}"; pad "$gap"
    rendercell "${2:-}"; pad "$gap"
    rendercell "${3:-}"
    printf '\n'
}

n=${#c1[@]}
[ ${#c2[@]} -gt "$n" ] && n=${#c2[@]}
[ ${#c3[@]} -gt "$n" ] && n=${#c3[@]}

echo
pad "$leftpad"; header "HOST SERVICES"; pad "$gap"
header "CONTAINERS"; pad "$gap"; header "CADDY SITES"
printf '\n\n'

for ((i = 0; i < n; i++)); do
    row "${c1[i]:-}" "${c2[i]:-}" "${c3[i]:-}"
done

echo
pad "$leftpad"; printf '%s%sHERMES%s   ' "$BOLD" "$CYAN" "$RST"
hermes_summary
printf '\n'
