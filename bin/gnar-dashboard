#!/bin/bash
# GNAR — multi-pane tmux dashboard.
#
# Layout — btop spans the full width up top (it wants the room: core grid,
# mem/disk/net/proc side by side), three status panes across the bottom:
#
#   ┌─────────────────────────────────────────────────────┐
#   │  btop  — system monitor (full width, ~60% height)    │
#   ├──────────────────┬─────────────────┬─────────────────┤
#   │ services + caddy │  docker + pm2   │  Hermes         │
#   │ (gnar-services)  │ (gnar-docker)   │  (gnar-hermes)  │
#   └──────────────────┴─────────────────┴─────────────────┘
#
# Each bottom pane gets ~1/3 of a wide kiosk display — generous enough that
# nothing truncates. Panes self-refresh with a plain loop rather than
# `watch`: `watch -c` miscounts ANSI colour codes and clips coloured lines
# mid-word, and `while :;` keeps a pane alive even if its command errors.
#
# `gnar-claude-stats` still exists as a one-shot — run it manually if you
# want a snapshot of Claude Code activity. Hermes is the day-to-day signal.
#
# Auto-attaches if the session already exists. Hyprland's `exec-once`
# launches `foot -e gnar-dashboard`, so on display attach this is your
# kiosk view. Run from any shell to attach manually.

set -uo pipefail

SESSION=dashboard

# Already running? Just attach.
if tmux has-session -t "$SESSION" 2>/dev/null; then
    exec tmux attach -t "$SESSION"
fi

# Build a self-refreshing pane command: clear + run + sleep, forever.
# `while :;` (not `while cmd`) means a transient command failure never
# tears the pane down.
loop() {  # loop <interval-seconds> <command>
    printf 'while :; do clear; %s; sleep %s; done' "$2" "$1"
}

# Top: btop, full width.
tmux new-session -d -s "$SESSION" -n main 'btop'

# Each split-window targets the window's *active* pane, and the freshly
# created pane becomes active — so the chain below carves the bottom 40%
# off btop, then halves that strip twice into thirds. Targeting the
# active pane (rather than .0/.1) keeps this correct under any
# `pane-base-index`.
tmux split-window -v -t "$SESSION:main" -l 40% "$(loop 30 gnar-services-status)"
tmux split-window -h -t "$SESSION:main" -l 66% "$(loop 10 gnar-docker-status)"
tmux split-window -h -t "$SESSION:main" -l 50% "$(loop 30 gnar-hermes-status)"

tmux select-pane  -t "$SESSION:main.{top-left}"
tmux set-option   -t "$SESSION" status off
tmux set-option   -t "$SESSION" mouse on

exec tmux attach -t "$SESSION"
