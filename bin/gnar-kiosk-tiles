#!/bin/bash
# GNAR — spawn the six kiosk dashboard tiles in deterministic order.
#
# Launched by mango's exec-once (see configs/mango-config.conf). Six
# parallel foot launches map in nondeterministic order, which scrambles
# tile placement — so launch one at a time with a beat in between.
# Mango's grid layout fills row-major in client order, so this
# sequence:
#
#   cpu mem net disk containers status
#
# lands as:
#
#   CPU   MEM         NET
#   DISK  CONTAINERS  STATUS
#
# Each tile runs `gnar-board <panel>` in a respawn loop so a crash
# never leaves a hole in the mosaic.

set -u

for panel in cpu mem net disk containers status; do
    foot --app-id="gnar-$panel" \
         -e sh -c "while :; do gnar-board $panel; sleep 2; done" &
    sleep 0.5
done
wait
