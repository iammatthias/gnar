# Static file server for a single preview site.
# Bound to :80 inside the tailscale netns. `tailscale serve` (run by the
# serve-config one-shot in docker-compose.yml) terminates TLS at :443 and
# proxies here.

:80 {
    root * /srv/site
    file_server
    encode gzip
    try_files {path} {path}/ /index.html
}
